entrypoint = "README.md"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"
packages = ["glib", "nss", "at-spi2-core", "cups", "gtk3", "alsa-lib", "dbus"]

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["github:1.0.0", "revenuecat:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"
waitForPort = 8081
ensurePreviewReachable = "/status"

[userenv]

[userenv.shared]
APP_VARIANT = "surge"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_XtKBxoFsRVhhzRidlqqkNLeBtAO"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appa8d0c25034"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "app79debf1e1d"
REVENUECAT_PROJECT_ID = "proj0f7f05c4"
REVENUECAT_TEST_STORE_APP_ID = "app079f70cf16"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appa8d0c25034"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app79debf1e1d"
EXPO_PUBLIC_ADMOB_IOS_APP_ID = "ca-app-pub-8066217004146663~5996324131"
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID = "ca-app-pub-8066217004146663~5996324131"
EXPO_PUBLIC_ADMOB_IOS_REWARDED_AD_UNIT_ID = "ca-app-pub-8066217004146663/7972318036"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
