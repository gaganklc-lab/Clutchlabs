{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "production-clutchtap": {
      "env": {
        "APP_VARIANT": "clutchtap"
      }
    },
    "production-velocity": {
      "env": {
        "APP_VARIANT": "velocity"
      }
    },
    "production-surge": {
      "env": {
        "APP_VARIANT": "surge"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {},
    "production-clutchtap": {},
    "production-velocity": {},
    "production-surge": {
      "ios": {
        "ascAppId": "6760904482"
      }
    }
  }
}
